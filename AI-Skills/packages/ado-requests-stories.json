{
  "name": "ado-requests-stories",
  "description": "Synchronizes Azure DevOps Work Items with Markdown artifacts under requests/stories/",
  "rules": [
    "rules/ado-skill.mdc"
  ],
  "skills": [
    "skills/ado"
  ],
  "agents": [
    "agents/ado-story-pruefe-agent.md",
    "agents/ado-task-pruefe-agent.md"
  ],
  "references": [
    "references/subagent-model-before-task.md"
  ],
  "params": [
    "{devops-pipelines-path}"
  ],
  "dependsOn": [
    "buddy-agent"
  ],
  "mcp": [
    {
      "serverName": "ado",
      "type": "simple",
      "params": [
        {
          "key": "ado-organisation",
          "label": "Azure DevOps Organisation",
          "placeholder": "__ORG__"
        },
        {
          "key": "ado-project",
          "label": "Azure DevOps Projekt",
          "placeholder": "__PROJECT__"
        },
        {
          "key": "ado-team",
          "label": "Azure DevOps Team (optional, Enter zum Ueberspringen)",
          "placeholder": "__TEAM__"
        }
      ],
      "entry": {
        "command": "npx",
        "args": [
          "-y",
          "@azure-devops/mcp",
          "__ORG__",
          "-d",
          "core",
          "work",
          "work-items"
        ],
        "env": {
          "ado_mcp_project": "__PROJECT__",
          "ado_mcp_team": "__TEAM__"
        }
      }
    }
  ],
  "docs": [
    "Readme.md"
  ]
}
