{
  "name": "code-review-mcp",
  "description": "Code-Review MCP: static analysis tools for Angular and .NET — AST, index, refactoring safety, nullability, auto-fixes",
  "rules": [
    "rules/code-review-mcp.mdc"
  ],
  "skills": [
    "skills/code-review-mcp"
  ],
  "agents": [],
  "references": [],
  "params": [],
  "dependsOn": [],
  "mcp": [
    {
      "serverName": "code-review-mcp",
      "type": "docker",
      "imageParamKey": "code-review-mcp-image",
      "pullAlwaysKey": "code-review-mcp-pull-always",
      "globalImage": "devesen/dv.code-review.mcp:latest",
      "localDefault": "code-review-mcp:local",
      "entry": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "-v",
          "${workspaceFolder}:/workspace:ro",
          "__IMAGE__"
        ],
        "transport": "stdio"
      },
      "entryPullAlways": {
        "command": "docker",
        "args": [
          "run",
          "-i",
          "--rm",
          "--pull",
          "always",
          "-v",
          "${workspaceFolder}:/workspace:ro",
          "__IMAGE__"
        ],
        "transport": "stdio"
      }
    }
  ],
  "docs": [
    "Readme.md"
  ]
}
