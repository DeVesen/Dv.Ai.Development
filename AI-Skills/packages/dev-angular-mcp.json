{
  "name": "dev-angular-mcp",
  "description": "Angular scaffolding and build/test via MCP: scaffold_angular_component, scaffold_angular_service, build_angular_project, test_angular_project. project_root as /workspace/... path.",
  "rules": [],
  "skills": [
    "skills/dev-angular-mcp"
  ],
  "agents": [],
  "references": [],
  "params": [],
  "dependsOn": [],
  "mcp": [
    {
      "serverName": "dev-angular-mcp",
      "type": "docker",
      "imageParamKey": "mcp-image-dev-angular-mcp",
      "pullAlwaysKey": "mcp-pull-dev-angular-mcp",
      "globalImage": "devesen/dev-angular-mcp:latest",
      "localDefault": "dev-angular-mcp:latest",
      "llmHint": [
        "Stärken: Angular-Komponenten und Services scaffolden · Angular-Projekt bauen und testen (Output intern gefiltert)",
        "Bevorzugt wenn: neue Komponente oder Service erstellen · ng build oder ng test ausführen",
        "Tools: scaffold_angular_component, scaffold_angular_service, build_angular_project, test_angular_project",
        "Skill: .cursor/skills/dev-angular-mcp/SKILL.md",
        "Mount: ${workspaceFolder}:/workspace (rw) · Parameter: project_root als /workspace/... Pfad"
      ],
      "entry": {
        "command": "docker",
        "args": [
          "run", "-i", "--rm",
          "-p", "127.0.0.1:8092:8092",
          "-v", "${workspaceFolder}:/workspace",
          "__IMAGE__"
        ],
        "transport": "stdio",
        "autoApprove": [
          "scaffold_angular_component",
          "scaffold_angular_service",
          "build_angular_project",
          "test_angular_project"
        ]
      },
      "entryPullAlways": {
        "command": "docker",
        "args": [
          "run", "-i", "--rm",
          "-p", "127.0.0.1:8092:8092",
          "--pull", "always",
          "-v", "${workspaceFolder}:/workspace",
          "__IMAGE__"
        ],
        "transport": "stdio",
        "autoApprove": [
          "scaffold_angular_component",
          "scaffold_angular_service",
          "build_angular_project",
          "test_angular_project"
        ]
      }
    }
  ]
}
