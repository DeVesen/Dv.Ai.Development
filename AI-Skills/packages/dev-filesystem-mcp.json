{
  "name": "dev-filesystem-mcp",
  "description": "Token-efficient file reading and searching via MCP: file_path and /project/... path conventions. Used by scouts and implementation agents for low-token codebase access.",
  "rules": [],
  "skills": [
    "skills/dev-filesystem-mcp"
  ],
  "agents": [],
  "references": [],
  "params": [],
  "dependsOn": [],
  "mcp": [
    {
      "serverName": "dev-filesystem-mcp",
      "type": "docker",
      "imageParamKey": "mcp-image-dev-filesystem-mcp",
      "pullAlwaysKey": "mcp-pull-dev-filesystem-mcp",
      "globalImage": "devesen/dev-filesystem-mcp:latest",
      "localDefault": "dev-filesystem-mcp:latest",
      "llmHint": [
        "Stärken: Gezieltes Klassen-Lesen, Signaturen, Interface-Implementierungen — token-effizient",
        "Bevorzugt wenn: konkrete Datei/Klasse bekannt · Public API prüfen · alle Implementierungen eines Interfaces finden",
        "Skill: .cursor/skills/dev-filesystem-mcp/SKILL.md",
        "Mount: ${workspaceFolder}:/project:ro (read-only) · Parameter: file_path, root (nicht path/filePath)"
      ],
      "entry": {
        "command": "docker",
        "args": [
          "run", "-i", "--rm",
          "-p", "127.0.0.1:8091:8091",
          "-v", "${workspaceFolder}:/project:ro",
          "-e", "PROJECT_ROOT=/project",
          "__IMAGE__"
        ],
        "transport": "stdio",
        "autoApprove": [
          "find_file",
          "find_by_content",
          "find_implementations",
          "read_signatures_only",
          "read_method",
          "read_class_summary"
        ]
      },
      "entryPullAlways": {
        "command": "docker",
        "args": [
          "run", "-i", "--rm",
          "-p", "127.0.0.1:8091:8091",
          "--pull", "always",
          "-v", "${workspaceFolder}:/project:ro",
          "-e", "PROJECT_ROOT=/project",
          "__IMAGE__"
        ],
        "transport": "stdio",
        "autoApprove": [
          "find_file",
          "find_by_content",
          "find_implementations",
          "read_signatures_only",
          "read_method",
          "read_class_summary"
        ]
      }
    }
  ]
}
