{
  "mcpServers": {
    "build-log-filter": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-p",
        "127.0.0.1:8089:8089",
        "devesen/build-log-filter-mcp:latest"
      ]
    },
    "codebase-analyzer": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-p",
        "127.0.0.1:8090:8090",
        "-v",
        "${CLAUDE_PROJECT_DIR:-.}:/workspace:ro",
        "devesen/codebase-analyzer-mcp:latest"
      ]
    },
    "ado": {
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "<IhreOrganisation>",
        "-d",
        "core",
        "work",
        "work-items"
      ]
    },
    "dev-filesystem-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-p",
        "127.0.0.1:8091:8091",
        "-v",
        "${CLAUDE_PROJECT_DIR:-.}:/project:ro",
        "-e",
        "PROJECT_ROOT=/project",
        "devesen/dev-filesystem-mcp:latest"
      ]
    },
    "dev-angular-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-p",
        "127.0.0.1:8092:8092",
        "-v",
        "${CLAUDE_PROJECT_DIR:-.}:/workspace",
        "devesen/dev-angular-mcp:latest"
      ]
    },
    "dev-dotnet-mcp": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-p",
        "127.0.0.1:8093:8093",
        "-v",
        "${CLAUDE_PROJECT_DIR:-.}:/workspace",
        "devesen/dev-dotnet-mcp:latest"
      ]
    }
  }
}
