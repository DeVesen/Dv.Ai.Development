{
  "name": "codebase-analyzer",
  "version": "2.6.0",
  "description": "MCP Server for Angular & .NET code reviews",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test:untested-api": "npm run build && node test-fixtures/untested-api/run-assertions.mjs",
    "test:type-hierarchy": "npm run build && node test-fixtures/type-hierarchy/run-assertions.mjs",
    "test:method-extraction": "npm run build && node test-fixtures/method-extraction/run-assertions.mjs",
    "test:god-classes": "npm run build && node test-fixtures/god-classes/run-assertions.mjs",
    "test:compiler-diagnostics": "npm run build && node test-fixtures/compiler-diagnostics/run-assertions.mjs",
    "test:index-solution": "npm run build && node test-fixtures/index-solution/run-assertions.mjs",
    "test:boyscout-actions": "npm run build && node test-fixtures/boyscout-actions/run-assertions.mjs"
  },
  "dependencies": {
"@modelcontextprotocol/sdk": "^1.12.0",
    "fast-xml-parser": "^5.8.0",
    "ts-morph": "^28.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
